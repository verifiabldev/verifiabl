# verifiabl.dev sandbox credentials (recorder only — agents never see these)
# Leave blank for local dev; recorder skips integrations with missing keys.

STRIPE_TEST_KEY=
SLACK_BOT_TOKEN=
HUBSPOT_ACCESS_TOKEN=

# Magic link signing
# Required in production.
SECRET_KEY=

# Local dev: magic links and 429 upgrade_url point here instead of production
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Email delivery
# Required for email sign-in.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Post-beta paid upgrades (not used by the current beta launch)
STRIPE_CHECKOUT_KEY=
STRIPE_PRICE_ID=

# Slack incoming webhook for new-signup notifications.
SLACK_SIGNUP_WEBHOOK=

# Required for admin usage access.
ADMIN_API_KEY=

# Optional: key for local dev; when set, seeded as free account so traffic tests show in admin usage
TEST_API_KEY=

# Set to 1 in production if you want /healthz to fail on placeholder secrets
STRICT_HEALTH_CHECKS=0
